<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="24dp"
    android:background="@drawable/bg_header_gradient">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivHeaderAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle" />

    <TextView
        android:id="@+id/tvHeaderWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Welcome back, Alex 👋"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/ivHeaderAvatar"
        app:layout_constraintStart_toEndOf="@id/ivHeaderAvatar"
        app:layout_constraintTop_toTopOf="@id/ivHeaderAvatar" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardNotification"
        android:layout_width="36dp"
        android:layout_height="36dp"
        app:cardCornerRadius="18dp"
        app:cardBackgroundColor="#1AFFFFFF"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="@id/ivHeaderAvatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/ivHeaderAvatar">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_popup_reminder"
                app:tint="@color/white" />

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:alpha="0.9"
                android:background="@drawable/bg_circle_indicator"
                android:backgroundTint="#E74C3C" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>