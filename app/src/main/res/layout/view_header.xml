<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    android:background="@drawable/bg_header_gradient"
    android:paddingHorizontal="20dp"
    android:paddingTop="16dp">

    <!-- Left: Calendar Icon -->
    <ImageView
        android:id="@+id/ivHeaderIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_my_calendar"
        app:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Center: Greeting -->
    <TextView
        android:id="@+id/tvHeaderWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome back, Alex 👋"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/cardNotification"
        app:layout_constraintStart_toEndOf="@id/ivHeaderIcon"
        app:layout_constraintTop_toTopOf="@id/ivHeaderIcon"
        app:layout_constraintBottom_toBottomOf="@id/ivHeaderIcon" />

    <!-- Right: Notification Bell -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardNotification"
        android:layout_width="32dp"
        android:layout_height="32dp"
        app:cardBackgroundColor="@color/glass_white"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/glass_border"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_popup_reminder"
                app:tint="@color/white" />

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_circle_indicator"
                android:backgroundTint="@color/danger" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>