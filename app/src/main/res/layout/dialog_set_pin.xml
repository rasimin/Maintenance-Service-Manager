<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_search_overlay"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="28dp">

    <!-- Icon -->
    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_circle_indicator"
        android:backgroundTint="#EEF2FF">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_secure"
            app:tint="@color/brand_primary" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvSetPinTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Set Your PIN"
        android:textColor="#1A1A2E"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSetPinSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="Create a 4-digit PIN to protect your app"
        android:textColor="#8A8A9A"
        android:textSize="13sp" />

    <!-- PIN Dots -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal">

        <View
            android:id="@+id/setupPinDot1"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/bg_circle_indicator"
            android:backgroundTint="#DDDDDD" />

        <View
            android:id="@+id/setupPinDot2"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/bg_circle_indicator"
            android:backgroundTint="#DDDDDD" />

        <View
            android:id="@+id/setupPinDot3"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/bg_circle_indicator"
            android:backgroundTint="#DDDDDD" />

        <View
            android:id="@+id/setupPinDot4"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/bg_circle_indicator"
            android:backgroundTint="#DDDDDD" />
    </LinearLayout>

    <!-- Error msg -->
    <TextView
        android:id="@+id/tvSetPinError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text=""
        android:textColor="@color/danger"
        android:textSize="12sp"
        android:visibility="invisible" />

    <!-- Numpad -->
    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:columnCount="3"
        android:rowCount="4">

        <!-- Row 1 -->
        <FrameLayout android:id="@+id/setupBtn1" android:layout_width="68dp" android:layout_height="68dp" android:layout_margin="6dp" android:background="@drawable/bg_pin_btn" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="1" android:textColor="#1A1A2E" android:textSize="24sp" android:textStyle="bold" />
        </FrameLayout>

        <FrameLayout android:id="@+id/setupBtn2" android:layout_width="68dp" android:layout_height="68dp" android:layout_margin="6dp" android:background="@drawable/bg_pin_btn" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="2" android:textColor="#1A1A2E" android:textSize="24sp" android:textStyle="bold" />
        </FrameLayout>

        <FrameLayout android:id="@+id/setupBtn3" android:layout_width="68dp" android:layout_height="68dp" android:layout_margin="6dp" android:background="@drawable/bg_pin_btn" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="3" android:textColor="#1A1A2E" android:textSize="24sp" android:textStyle="bold" />
        </FrameLayout>

        <!-- Row 2 -->
        <FrameLayout android:id="@+id/setupBtn4" android:layout_width="68dp" android:layout_height="68dp" android:layout_margin="6dp" android:background="@drawable/bg_pin_btn" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="4" android:textColor="#1A1A2E" android:textSize="24sp" android:textStyle="bold" />
        </FrameLayout>

        <FrameLayout android:id="@+id/setupBtn5" android:layout_width="68dp" android:layout_height="68dp" android:layout_margin="6dp" android:background="@drawable/bg_pin_btn" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="5" android:textColor="#1A1A2E" android:textSize="24sp" android:textStyle="bold" />
        </FrameLayout>

        <FrameLayout android:id="@+id/setupBtn6" android:layout_width="68dp" android:layout_height="68dp" android:layout_margin="6dp" android:background="@drawable/bg_pin_btn" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="6" android:textColor="#1A1A2E" android:textSize="24sp" android:textStyle="bold" />
        </FrameLayout>

        <!-- Row 3 -->
        <FrameLayout android:id="@+id/setupBtn7" android:layout_width="68dp" android:layout_height="68dp" android:layout_margin="6dp" android:background="@drawable/bg_pin_btn" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="7" android:textColor="#1A1A2E" android:textSize="24sp" android:textStyle="bold" />
        </FrameLayout>

        <FrameLayout android:id="@+id/setupBtn8" android:layout_width="68dp" android:layout_height="68dp" android:layout_margin="6dp" android:background="@drawable/bg_pin_btn" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="8" android:textColor="#1A1A2E" android:textSize="24sp" android:textStyle="bold" />
        </FrameLayout>

        <FrameLayout android:id="@+id/setupBtn9" android:layout_width="68dp" android:layout_height="68dp" android:layout_margin="6dp" android:background="@drawable/bg_pin_btn" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="9" android:textColor="#1A1A2E" android:textSize="24sp" android:textStyle="bold" />
        </FrameLayout>

        <!-- Row 4 -->
        <Space android:layout_width="68dp" android:layout_height="68dp" android:layout_margin="6dp" />

        <FrameLayout android:id="@+id/setupBtn0" android:layout_width="68dp" android:layout_height="68dp" android:layout_margin="6dp" android:background="@drawable/bg_pin_btn" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="0" android:textColor="#1A1A2E" android:textSize="24sp" android:textStyle="bold" />
        </FrameLayout>

        <FrameLayout android:id="@+id/setupBtnBackspace" android:layout_width="68dp" android:layout_height="68dp" android:layout_margin="6dp" android:background="@drawable/bg_pin_btn_action" android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@android:drawable/ic_input_delete" app:tint="#E74C3C" />
        </FrameLayout>

    </GridLayout>

    <!-- Cancel button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancelSetPin"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Cancel"
        android:textAllCaps="false"
        android:textColor="#8A8A9A"
        app:rippleColor="@color/divider" />

</LinearLayout>
