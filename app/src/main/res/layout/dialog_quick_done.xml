<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_search_overlay"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Header Icon -->
    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_next_service_rounded"
        android:backgroundTint="#E8F8F0">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="✅"
            android:textSize="28sp" />
    </FrameLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Quick Maintenance Done"
        android:textColor="#1A1A2E"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Automatically record maintenance completion for this device today."
        android:textColor="#8A8A9A"
        android:textSize="13sp" />

    <!-- Details Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="#F8F9FA"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="#E5E7EB"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Device"
                android:textColor="#8A8A9A"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvQuickDeviceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#1A1A2E"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="AC Ruang Tamu" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="#E5E7EB" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textColor="#8A8A9A"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvQuickDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#1A1A2E"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="08 Mar 2026" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="#E5E7EB" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estimated Service Cost"
                android:textColor="#8A8A9A"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvQuickCost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#27AE60"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Rp 250.000" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuickCancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="#8A8A9A"
            android:textAllCaps="false"
            app:cornerRadius="12dp"
            app:strokeColor="#E5E7EB" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuickSave"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Save Record"
            android:textAllCaps="false"
            app:backgroundTint="@color/brand_primary"
            app:cornerRadius="12dp" />
    </LinearLayout>

</LinearLayout>
