<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_search_overlay"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Header Icon -->
    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_next_service_rounded"
        android:backgroundTint="#F0F3FF">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_notif_bell"
            app:tint="@color/brand_primary" />
    </FrameLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Pilih Jam Notifikasi"
        android:textColor="#1A1A2E"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="Tentukan jam berapa pengingat akan dikirim setiap harinya."
        android:textColor="#8A8A9A"
        android:textSize="13sp" />

    <!-- Time Selection Container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_next_service_rounded"
        android:backgroundTint="#F8F9FF"
        android:padding="16dp">

        <NumberPicker
            android:id="@+id/npHour"
            android:layout_width="60dp"
            android:layout_height="140dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginHorizontal="12dp"
            android:text=":"
            android:textColor="#1A1A2E"
            android:textSize="24sp"
            android:textStyle="bold" />

        <NumberPicker
            android:id="@+id/npMinute"
            android:layout_width="60dp"
            android:layout_height="140dp" />

    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelTime"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="Batal"
            android:textColor="#8A8A9A"
            android:textAllCaps="false"
            app:cornerRadius="16dp"
            app:strokeColor="#E5E7EB" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveTime"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Simpan"
            android:textAllCaps="false"
            app:backgroundTint="@color/brand_primary"
            app:cornerRadius="16dp" />
    </LinearLayout>

</LinearLayout>
