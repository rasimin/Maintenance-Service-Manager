<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Header with back button -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <include
            android:id="@+id/header"
            layout="@layout/view_header_back" />

    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Background revealed on overscroll down -->
        <LinearLayout
            android:id="@+id/llSwipeEditBg"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:gravity="center"
            android:orientation="vertical"
            android:background="#EFEEFC"
            android:alpha="0">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/brand_primary" />

            <TextView
                android:id="@+id/tvSwipeEditText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Pull down to Edit Device"
                android:textColor="@color/brand_primary"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollViewDetail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="120dp"
            android:background="@color/background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Pull down indicator -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="↓ Pull down to edit device details"
                android:gravity="center"
                android:textColor="#C0C0D0"
                android:textSize="10sp"
                android:layout_marginBottom="6dp"
                android:letterSpacing="0.05" />

            <!-- ── Main Info Card Wrapper ── -->
            <com.example.servicemaintainreminder.ui.SwipeCardLayout
                android:id="@+id/sclMainInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Background Card for Swipe -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        
                        <!-- Left side (Delete) -->
                        <LinearLayout
                            android:id="@+id/llSwipeDeleteAreaDetail"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#E74C3C"
                            android:gravity="center_vertical|start"
                            android:paddingStart="24dp"
                            android:alpha="0">
                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@android:drawable/ic_menu_delete"
                                app:tint="@color/white" />
                        </LinearLayout>

                        <!-- Right side (Quick Done) -->
                        <LinearLayout
                            android:id="@+id/llSwipeDoneAreaDetail"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#E8F8F0"
                            android:gravity="center_vertical|end"
                            android:paddingEnd="24dp"
                            android:alpha="0">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Quick Done ✅"
                                android:textColor="#27AE60"
                                android:textStyle="bold"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── Main Info Card ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvMainInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Status strip top -->
                    <FrameLayout
                        android:id="@+id/flDetailStatusHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="8dp"
                        android:paddingHorizontal="20dp"
                        android:background="#F0F9F4">

                        <TextView
                            android:id="@+id/tvStatusIndicator"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="✅ Scheduled"
                            tools:textColor="#2ECC71" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- Name + Active Toggle row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <View
                                    android:id="@+id/viewDetailIconBg"
                                    android:layout_width="44dp"
                                    android:layout_height="44dp"
                                    android:background="@drawable/bg_circle_indicator"
                                    android:backgroundTint="#EEF2FF" />

                                <ImageView
                                    android:id="@+id/ivDetailIcon"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginStart="-32dp"
                                    android:src="@drawable/ic_devices"
                                    app:tint="@color/brand_primary" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="12dp"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvDetailName"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="#1A1A2E"
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        tools:text="AC Ruang Tamu" />

                                    <TextView
                                        android:id="@+id/tvDetailCategory"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="2dp"
                                        android:textColor="@color/brand_primary"
                                        android:textSize="13sp"
                                        tools:text="Elektronik" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Active Toggle moved to header -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="end">

                                <TextView
                                    android:id="@+id/tvActiveLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Status"
                                    android:textColor="@color/brand_primary"
                                    android:textSize="9sp"
                                    android:textStyle="bold"
                                    android:background="@drawable/bg_status_badge"
                                    android:backgroundTint="#EEF2FF"
                                    android:paddingHorizontal="6dp"
                                    android:paddingVertical="2dp" />

                                <com.google.android.material.switchmaterial.SwitchMaterial
                                    android:id="@+id/swActiveDetail"
                                    android:layout_width="wrap_content"
                                    android:layout_height="24dp"
                                    android:layout_marginTop="2dp"
                                    android:checked="true"
                                    app:thumbTint="@color/white"
                                    app:trackTint="@color/brand_primary"
                                    app:useMaterialThemeColors="false" />
                            </LinearLayout>

                        </LinearLayout>

                        <!-- Next Maintenance Highlight Box -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_next_service_rounded"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.08"
                                android:text="NEXT MAINTENANCE"
                                android:textColor="#8A8A9A"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvDetailNextService"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/brand_primary"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="06 Apr 2026" />

                            <!-- Schedule Type Badge -->
                            <TextView
                                android:id="@+id/tvScheduleTypeBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_status_badge"
                                android:backgroundTint="#EEF2FF"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="3dp"
                                android:textColor="@color/brand_primary"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                tools:text="🔄 Flexible Schedule" />

                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="12dp"
                            android:background="@color/divider" />

                        <!-- Stats Grid: 2x2 -->
                        <!-- Row 1: Last Service | Service Interval -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp"
                            android:baselineAligned="false">

                            <!-- Last Service -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:padding="4dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Last Service"
                                    android:textColor="@color/brand_primary"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:background="@drawable/bg_status_badge"
                                    android:backgroundTint="#EEF2FF"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="3dp" />

                                <TextView
                                    android:id="@+id/tvDetailLastService"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:textColor="#1A1A2E"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    tools:text="07 Mar 2026" />
                            </LinearLayout>

                            <View
                                android:layout_width="10dp"
                                android:layout_height="0dp" />

                            <!-- Service Interval -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:padding="4dp"
                                android:gravity="end">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Interval"
                                    android:textColor="#27AE60"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:background="@drawable/bg_status_badge"
                                    android:backgroundTint="#E8F8F0"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="3dp" />

                                <TextView
                                    android:id="@+id/tvDetailInterval"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:textColor="#1A1A2E"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    tools:text="30 Days" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Row 2: Total Cost | Estimated Cost -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:baselineAligned="false">

                            <!-- Total Cost -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:padding="4dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Cost"
                                    android:textColor="#E67E22"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:background="@drawable/bg_status_badge"
                                    android:backgroundTint="#FFF3E0"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="3dp" />

                                <TextView
                                    android:id="@+id/tvDetailTotalCost"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:textColor="#1A1A2E"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    tools:text="Rp 0" />
                            </LinearLayout>

                            <View
                                android:layout_width="10dp"
                                android:layout_height="0dp" />

                            <!-- Estimated Cost / Svc -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:padding="4dp"
                                android:gravity="end">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Estimated Cost / Svc"
                                    android:textColor="#8E44AD"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:background="@drawable/bg_status_badge"
                                    android:backgroundTint="#F5EEF8"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="3dp" />

                                <TextView
                                    android:id="@+id/tvDetailEstimatedCost"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:textColor="#1A1A2E"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    tools:text="Rp 0" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Note Row -->
                        <LinearLayout
                            android:id="@+id/llNoteContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="4dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_input_note"
                                app:tint="@color/brand_primary" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Note"
                                    android:textColor="#8A8A9A"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/tvDetailNote"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:textColor="#1A1A2E"
                                    android:textSize="14sp"
                                    tools:text="Optional notes..." />
                            </LinearLayout>

                            <!-- More Options (Edit, Delete, Quick Done) -->
                            <ImageButton
                                android:id="@+id/btnMoreOptions"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@drawable/ic_more_vert"
                                app:tint="#8A8A9A"
                                android:contentDescription="More Options" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            </com.example.servicemaintainreminder.ui.SwipeCardLayout>

            <!-- ── Maintenance History Section ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Maintenance History"
                        android:textColor="#1A1A2E"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="swipe to delete →"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddHistory"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:minHeight="0dp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="0dp"
                    android:text="Add"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/brand_primary"
                    app:cornerRadius="8dp"
                    app:icon="@android:drawable/ic_input_add"
                    app:iconSize="14dp"
                    app:iconTint="@color/white" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_history" />

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/llEmptyHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:alpha="0.2"
                    android:src="@android:drawable/ic_menu_recent_history"
                    app:tint="@color/brand_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="No maintenance history yet"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tap '+ Add Maintenance' to record one"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    </FrameLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddHistoryMini"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:layout_gravity="bottom|end"
        android:visibility="invisible"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/brand_primary"
        app:tint="@color/white"
        app:elevation="4dp"
        app:fabSize="mini" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
