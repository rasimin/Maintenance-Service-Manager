<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:clickable="true"
    android:focusable="true">

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Lock Icon -->
        <FrameLayout
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:background="@drawable/bg_circle_indicator"
            android:backgroundTint="#EEF2FF">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_secure"
                app:tint="@color/brand_primary" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Welcome Back"
            android:textColor="#1A1A2E"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPinSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Enter your PIN to continue"
            android:textColor="#8A8A9A"
            android:textSize="14sp" />

        <!-- PIN Dots -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="horizontal">

            <View
                android:id="@+id/pinDot1"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/bg_circle_indicator"
                android:backgroundTint="#DDDDDD" />

            <View
                android:id="@+id/pinDot2"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/bg_circle_indicator"
                android:backgroundTint="#DDDDDD" />

            <View
                android:id="@+id/pinDot3"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/bg_circle_indicator"
                android:backgroundTint="#DDDDDD" />

            <View
                android:id="@+id/pinDot4"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/bg_circle_indicator"
                android:backgroundTint="#DDDDDD" />
        </LinearLayout>

        <!-- Error message -->
        <TextView
            android:id="@+id/tvPinError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Incorrect PIN, try again"
            android:textColor="@color/danger"
            android:textSize="12sp"
            android:visibility="invisible" />

        <!-- Numpad -->
        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:columnCount="3"
            android:rowCount="4">

            <!-- Row 1: 1, 2, 3 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn1"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="38dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="#1A1A2E"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn2"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="38dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="#1A1A2E"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn3"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="38dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="#1A1A2E"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Row 2: 4, 5, 6 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn4"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="38dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="4"
                    android:textColor="#1A1A2E"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn5"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="38dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="5"
                    android:textColor="#1A1A2E"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn6"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="38dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="6"
                    android:textColor="#1A1A2E"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Row 3: 7, 8, 9 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn7"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="38dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="7"
                    android:textColor="#1A1A2E"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn8"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="38dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="8"
                    android:textColor="#1A1A2E"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn9"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="38dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="9"
                    android:textColor="#1A1A2E"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Row 4: Biometric, 0, Backspace -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBiometric"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                app:cardBackgroundColor="#EEF2FF"
                app:cardCornerRadius="38dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_secure"
                    app:tint="@color/brand_primary" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Empty space if biometric hidden -->
            <Space
                android:id="@+id/spaceBottomLeft"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:visibility="visible" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn0"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="38dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="#1A1A2E"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBackspace"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#FFF5F5"
                app:cardCornerRadius="38dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_input_delete"
                    app:tint="#E74C3C" />
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
