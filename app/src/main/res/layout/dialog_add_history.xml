<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="8dp"
    android:background="@color/white">


    <!-- Service Description -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Service Description"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxStrokeColor="@color/input_stroke_color"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="1.5dp"
        app:hintTextColor="@color/brand_primary"
        app:startIconDrawable="@drawable/ic_input_edit"
        app:startIconTint="@color/brand_primary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etHistoryDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_placeholder"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Maintenance Cost -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:hint="Maintenance Cost (Rp)"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxStrokeColor="@color/input_stroke_color"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="1.5dp"
        app:hintTextColor="@color/brand_primary"
        app:startIconDrawable="@drawable/ic_input_info"
        app:startIconTint="@color/brand_primary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etHistoryCost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_placeholder"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Service Date -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:hint="Service Date"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxStrokeColor="@color/input_stroke_color"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="1.5dp"
        app:hintTextColor="@color/brand_primary"
        app:startIconDrawable="@drawable/ic_input_calendar"
        app:startIconTint="@color/brand_primary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etHistoryDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="false"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_placeholder"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Bottom spacing for dialog buttons -->
    <View
        android:layout_width="match_parent"
        android:layout_height="8dp" />

</LinearLayout>
