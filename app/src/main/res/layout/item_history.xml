<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="5dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Date Badge -->
        <LinearLayout
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_circle_indicator"
            android:backgroundTint="@color/stats_blue_bg"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvHistoryDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="07" />

            <TextView
                android:id="@+id/tvHistoryMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="MAR" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="14dp"
            android:background="@color/divider" />

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvHistoryDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1A1A2E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="2"
                tools:text="Ganti oli mesin" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="@drawable/bg_status_badge"
                android:backgroundTint="@color/stats_orange_bg"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰 "
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvHistoryCost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#E67E22"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="Rp 50.000" />
            </LinearLayout>
        </LinearLayout>

        <!-- Hidden full date for adapter use -->
        <TextView
            android:id="@+id/tvHistoryDate"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            tools:text="07 Mar 2026" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
