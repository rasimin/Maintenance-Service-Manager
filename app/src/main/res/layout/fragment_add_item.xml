<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient">

    <include
        android:id="@+id/header"
        layout="@layout/view_header_back"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollViewAddItem"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomSaveBar"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Form Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Card Header Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Titles -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Item Details"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Fill in the maintenance information below"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Active Toggle moved to header -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Status"
                                android:textColor="@color/brand_primary"
                                android:textSize="9sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_status_badge"
                                android:backgroundTint="#EEF2FF"
                                android:paddingHorizontal="6dp"
                                android:paddingVertical="2dp" />

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switchActive"
                                android:layout_width="wrap_content"
                                android:layout_height="24dp"
                                android:layout_marginTop="2dp"
                                android:checked="true"
                                app:thumbTint="@color/white"
                                app:trackTint="@color/brand_primary"
                                app:useMaterialThemeColors="false" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="20dp"
                        android:background="@color/divider" />

                    <!-- ── Item Name ── -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilName"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Item Name"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="@color/input_stroke_color"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="1.5dp"
                        app:hintTextColor="@color/brand_primary"
                        app:startIconDrawable="@drawable/ic_input_edit"
                        app:startIconTint="@color/brand_primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_placeholder"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- ── Category ── -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilCategory"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Category"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="@color/input_stroke_color"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="1.5dp"
                        app:hintTextColor="@color/brand_primary"
                        app:startIconDrawable="@drawable/ic_input_category"
                        app:startIconTint="@color/brand_primary">

                        <AutoCompleteTextView
                            android:id="@+id/spinnerCategory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <!-- ── Icon Selection ── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="8dp"
                        android:text="Choose Icon"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/llIconContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="4dp">
                            <!-- Icons will be added dynamically or statically -->
                        </LinearLayout>
                    </HorizontalScrollView>

                    <!-- ── Schedule Type Compact Selector ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:text="Schedule Type"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:letterSpacing="0.05"
                            android:textStyle="bold" />

                        <!-- Card Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Option: Rolling -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cardFlexible"
                                android:layout_width="0dp"
                                android:layout_height="56dp"
                                android:layout_weight="1"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardBackgroundColor="#EDF1FF"
                                app:cardCornerRadius="12dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/brand_primary"
                                app:strokeWidth="1.5dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:paddingHorizontal="12dp">

                                    <ImageView
                                        android:id="@+id/ivFlexibleIcon"
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:src="@drawable/ic_schedule_flexible"
                                        app:tint="@color/brand_primary" />

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Rolling"
                                            android:textColor="@color/brand_primary"
                                            android:textSize="12sp"
                                            android:textStyle="bold" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Ikut tanggal servis"
                                            android:textColor="@color/brand_primary"
                                            android:alpha="0.6"
                                            android:textSize="9sp" />

                                    </LinearLayout>

                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <View
                                android:layout_width="8dp"
                                android:layout_height="0dp" />

                            <!-- Option: Fixed -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cardFixed"
                                android:layout_width="0dp"
                                android:layout_height="56dp"
                                android:layout_weight="1"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardBackgroundColor="#F5F5F7"
                                app:cardCornerRadius="12dp"
                                app:cardElevation="0dp"
                                app:strokeColor="#DEDEDE"
                                app:strokeWidth="1.5dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:paddingHorizontal="12dp">

                                    <ImageView
                                        android:id="@+id/ivFixedIcon"
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:src="@drawable/ic_schedule_fixed"
                                        app:tint="#AAAAAA" />

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:id="@+id/tvFixedLabel"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Fixed"
                                            android:textColor="#AAAAAA"
                                            android:textSize="12sp"
                                            android:textStyle="bold" />

                                        <TextView
                                            android:id="@+id/tvFixedSubLabel"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Tanggal tetap"
                                            android:textColor="#BBBBBB"
                                            android:textSize="9sp" />

                                    </LinearLayout>

                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                        </LinearLayout>

                        <!-- Dynamic Description Box -->
                        <LinearLayout
                            android:id="@+id/llScheduleDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_status_badge"
                            android:backgroundTint="#EEF2FF"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="12dp">

                            <TextView
                                android:id="@+id/tvScheduleDescIcon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔄"
                                android:textSize="16sp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvScheduleDescTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Rolling"
                                    android:textColor="@color/brand_primary"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvScheduleDescBody"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Jadwal berikutnya = Tgl Servis Terakhir + Interval. Jadwal mengikuti kapan kamu servis."
                                    android:textColor="@color/brand_primary"
                                    android:alpha="0.75"
                                    android:textSize="11sp"
                                    android:lineSpacingExtra="2dp" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- ── Last Service Date ── -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilLastServiceDate"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Last Service Date"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="@color/input_stroke_color"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="1.5dp"
                        app:hintTextColor="@color/brand_primary"
                        app:startIconDrawable="@drawable/ic_input_calendar"
                        app:startIconTint="@color/brand_primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etLastServiceDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="false"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_placeholder"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- ── Interval + Unit Row ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilInterval"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Interval"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxStrokeColor="@color/input_stroke_color"
                            app:boxStrokeWidth="1dp"
                            app:boxStrokeWidthFocused="1.5dp"
                            app:hintTextColor="@color/brand_primary"
                            app:startIconTint="@color/brand_primary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etIntervalValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_placeholder"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggleUnit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            app:checkedButton="@+id/btnUnitMonths"
                            app:singleSelection="true"
                            app:selectionRequired="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnUnitMonths"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="54dp"
                                android:text="Months"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                app:cornerRadius="12dp"
                                app:strokeColor="@color/input_stroke_color" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnUnitDays"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="54dp"
                                android:text="Days"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                app:cornerRadius="12dp"
                                app:strokeColor="@color/input_stroke_color" />

                        </com.google.android.material.button.MaterialButtonToggleGroup>

                    </LinearLayout>

                    <!-- ── Estimated Cost per Service ── -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEstimatedCost"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Estimated Cost per Service (Rp)"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="@color/input_stroke_color"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="1.5dp"
                        app:hintTextColor="@color/brand_primary"
                        app:startIconDrawable="@drawable/ic_input_cost"
                        app:startIconTint="@color/brand_primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEstimatedCost"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_placeholder"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- ── Note ── -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Note (Optional)"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="@color/input_stroke_color"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="1.5dp"
                        app:hintTextColor="@color/brand_primary"
                        app:startIconDrawable="@drawable/ic_input_note"
                        app:startIconTint="@color/brand_primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top"
                            android:minLines="3"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_placeholder"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>


                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Sticky Bottom Save Bar ── -->
    <LinearLayout
        android:id="@+id/bottomSaveBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Top divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="12dp"
            android:text="Save Item"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="@color/brand_primary"
            app:cornerRadius="14dp"
            app:icon="@android:drawable/ic_menu_save"
            app:iconTint="@color/white"
            app:iconGravity="textStart"
            app:elevation="0dp" />

    </LinearLayout>

    <!-- Gradient fade overlay: floats above sticky bar, overlays scroll content -->
    <View
        android:id="@+id/viewScrollFade"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_scroll_bottom_fade"
        android:importantForAccessibility="no"
        android:elevation="7dp"
        app:layout_constraintBottom_toTopOf="@id/bottomSaveBar" />

</androidx.constraintlayout.widget.ConstraintLayout>