<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Icon circle -->
            <FrameLayout
                android:id="@+id/flIconBackground"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_indicator"
                android:backgroundTint="@color/brand_primary">

                <ImageView
                    android:id="@+id/ivSearchItemIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_devices"
                    app:tint="@color/white" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:id="@+id/tvSearchItemName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="Service Motor"
                    android:textColor="#2A2A3A"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvSearchItemCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="Kendaraan"
                    android:textColor="#888A9A"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Status Badge -->
            <TextView
                android:id="@+id/tvSearchStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                tools:text="26 days left"
                tools:textColor="@color/status_safe"
                tools:backgroundTint="@color/status_safe_bg"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="#f0f2f8" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_input_calendar"
                app:tint="#888A9A" />

            <TextView
                android:id="@+id/tvSearchNextDate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                tools:text="Servis: 04 Apr 2026"
                android:textColor="#888A9A"
                android:textSize="12sp"
                android:layout_marginStart="6dp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_right"
                app:tint="#D0D2D8" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
