<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_search_overlay">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Header ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pengaturan"
                android:textColor="#111827"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Kelola akun, keamanan &amp; preferensi"
                android:textColor="#9CA3AF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- ════════════════════════════════════════════ -->
        <!--  SECTION: AKUN                              -->
        <!-- ════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F3F4F6"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:text="AKUN"
            android:textColor="#6B7280"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />

        <!-- Account Name Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_person"
                app:tint="#6366F1" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Akun"
                    android:textColor="#111827"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCurrentAccountName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="—"
                android:textColor="#9CA3AF"
                android:textSize="13sp" />

            <ImageView
                android:id="@+id/btnChangeAccount"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="#D1D5DB" />
        </LinearLayout>

        <!-- ════════════════════════════════════════════ -->
        <!--  SECTION: KEAMANAN                          -->
        <!-- ════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F3F4F6"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:text="KEAMANAN"
            android:textColor="#6B7280"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />

        <!-- App Lock -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_lock"
                app:tint="#6366F1" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kunci Aplikasi"
                    android:textColor="#111827"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lindungi app dengan PIN &amp; biometrik"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp" />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchAppLock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Security Status (visible only when lock is on) -->
        <LinearLayout
            android:id="@+id/llSecurityStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Thin inset divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.8dp"
                android:layout_marginStart="52dp"
                android:background="#E5E7EB" />

            <!-- PIN Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_pin"
                    app:tint="#6366F1" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PIN"
                        android:textColor="#111827"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvPinStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Belum diset"
                        android:textColor="#EF4444"
                        android:textSize="11sp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChangePinInline"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingHorizontal="0dp"
                    android:text="Ganti"
                    android:textAllCaps="false"
                    android:textColor="@color/brand_primary"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Thin inset divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.8dp"
                android:layout_marginStart="52dp"
                android:background="#E5E7EB" />

            <!-- Biometric Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_fingerprint"
                    app:tint="#6366F1" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Biometrik"
                        android:textColor="#111827"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvBiometricStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nonaktif"
                        android:textColor="#9CA3AF"
                        android:textSize="11sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchBiometric"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:enabled="false" />
            </LinearLayout>
        </LinearLayout>

        <!-- ════════════════════════════════════════════ -->
        <!--  SECTION: NOTIFIKASI                        -->
        <!-- ════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F3F4F6"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:text="NOTIFIKASI"
            android:textColor="#6B7280"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />

        <!-- Notification Time Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_notif_bell"
                app:tint="#6366F1" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jam Pengingat"
                    android:textColor="#111827"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvNotifTimeDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Setiap hari pukul 08:00"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTestNotif"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="8dp"
                android:text="Test"
                android:textAllCaps="false"
                android:textColor="#EF4444"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChangeNotifTime"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="4dp"
                android:text="Ubah"
                android:textAllCaps="false"
                android:textColor="@color/brand_primary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ════════════════════════════════════════════ -->
        <!--  SECTION: DASHBOARD                         -->
        <!-- ════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F3F4F6"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:text="DASHBOARD"
            android:textColor="#6B7280"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />

        <!-- Threshold Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_dashboard"
                app:tint="#6366F1" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Batas Upcoming"
                    android:textColor="#111827"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvThresholdDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tampilkan item 30 hari ke depan"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChangeThreshold"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="4dp"
                android:text="Ubah"
                android:textAllCaps="false"
                android:textColor="@color/brand_primary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Bottom section filler + close button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F3F4F6"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="28dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCloseSettings"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Tutup"
                android:textColor="#6B7280"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:cornerRadius="10dp"
                app:strokeColor="#D1D5DB"
                app:strokeWidth="1dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
