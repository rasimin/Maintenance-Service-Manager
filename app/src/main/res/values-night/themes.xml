<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ServiceMaintainReminder" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Force dark mode to use the same light colors for a consistent look -->
        <item name="colorPrimary">@color/gradient_start</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>

        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">@color/gradient_start</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Smooth transitions and elevations -->
        <item name="elevationOverlayEnabled">false</item>
    </style>
</resources>